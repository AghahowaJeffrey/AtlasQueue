# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atlasqueue:atlasqueue@postgres:5432/atlasqueue

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Queue keys ────────────────────────────────────────────────────────────────
JOB_QUEUE_KEY=atlasqueue:jobs
DLQ_KEY=atlasqueue:dlq

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_LEASE_SECONDS=30
WORKER_POLL_TIMEOUT=5

# ── Retry policy ─────────────────────────────────────────────────────────────
RETRY_BASE_DELAY_SECONDS=5
RETRY_JITTER_MAX_SECONDS=2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SERVICE_NAME=atlasqueue
